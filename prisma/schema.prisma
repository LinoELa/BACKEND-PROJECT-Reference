// Este es el esquema principal de Prisma.
// Aqui definimos la conexion a la base de datos, el cliente y los modelos.

// Genera el cliente de Prisma para poder hacer consultas desde Node.js.
generator client {
  provider = "prisma-client-js"
}

// Define que este proyecto usa PostgreSQL como base de datos.
datasource db {
  provider = "postgresql"
}

// Tabla de usuarios de la aplicacion.
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique // El email no se puede repetir entre usuarios.
  password  String
  createdAt DateTime @default(now())

  reviews        Review[] // Un usuario puede escribir muchas reviews.
  watchlistItems watchlistItem[]
}

// Tabla de peliculas.
model Movie {
  id             Int             @id @default(autoincrement())
  title          String
  overview       String? // Resumen corto opcional.
  description    String
  releaseDate    DateTime
  genres         String[]        @default([]) // PostgreSQL permite arrays de texto.
  runtime        Int?
  posterUrl      String?
  createdBy      String // Guarda quien creo el registro de la pelicula.
  createdAt      DateTime        @default(now())
  reviews        Review[] // Una pelicula puede tener muchas reviews.
  watchlistItems watchlistItem[] // Una pelicula puede estar en muchas watchlists.
}

// Tabla de reviews: conecta usuarios con peliculas y guarda su valoracion.
model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  movieId   Int // Clave foranea hacia Movie.
  userId    Int
  createdAt DateTime @default(now())

  // Relaciones
  movie Movie @relation(fields: [movieId], references: [id]) // Cada review pertenece a una pelicula. 

  user User @relation(fields: [userId], references: [id])
}

// Estados posibles de una pelicula dentro de la watchlist.
enum WATCHLIST_STATUS {
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}

// Tabla intermedia entre usuarios y peliculas para la watchlist.
model watchlistItem {
  id      Int              @id @default(autoincrement())
  movieId Int // Clave foranea hacia Movie.
  userId  Int
  status  WATCHLIST_STATUS @default(PLANNED) // Estado actual en la watchlist.
  rating  Int?
  notes   String? // Notas opcionales del usuario.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade) // Cada review pertenece a un usuario.
  movie Movie @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId]) // Evita duplicar la misma pelicula en la watchlist de un usuario.
}
